{
  "name": "leyang-portfolio-site",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1",
    "build": "next build",
    "start": "next start --hostname 127.0.0.1",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:dev": "playwright test --config=playwright.dev.config.ts",
    "check:public": "node scripts/check_public_output.mjs",
    "qa": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm test:e2e && pnpm check:public"
  },
  "dependencies": {
    "motion": "12.42.2",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/compat": "2.1.0",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.2",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@typescript/native": "npm:typescript@7.0.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.6.0",
    "eslint-config-next": "16.2.10",
    "jsdom": "29.1.1",
    "tailwindcss": "4.3.2",
    "typescript": "npm:@typescript/typescript6@6.0.2",
    "vite": "8.1.4",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.10"
  }
}
